{
  "version": 1,
  "project": {
    "name": "lebonplan",
    "rootPath": "C:\\PROJETS\\lebonplan",
    "platform": "windows"
  },
  "terminal": {
    "engine": "windows-terminal",
    "reuseWindow": false
  },
  "apps": [
    {
      "id": "docker-desktop",
      "kind": "desktop-app",
      "dependsOn": [],
      "launch": {
        "strategy": "executable",
        "path": "C:\\Program Files\\Docker\\Docker\\Docker Desktop.exe"
      },
      "startPolicy": {
        "defaultAction": "always"
      },
      "stopPolicy": {
        "defaultAction": "ask"
      },
      "checks": {
        "start": {
          "mode": "all",
          "items": [
            {
              "type": "command",
              "command": "docker info",
              "retry": {
                "maxAttempts": 60,
                "delayMs": 2000
              }
            }
          ]
        },
        "status": {
          "mode": "all",
          "items": [
            {
              "type": "command",
              "command": "docker info"
            }
          ]
        }
      }
    }
  ],
  "services": [
    {
      "id": "docker-compose",
      "kind": "project-command",
      "interactive": false,
      "tabName": null,
      "workingDirectory": "C:\\PROJETS\\lebonplan",
      "command": "docker compose up -d",
      "dependsOn": [
        "docker-desktop"
      ],
      "startPolicy": {
        "defaultAction": "always"
      },
      "stopPolicy": {
        "defaultAction": "always",
        "command": "docker compose down"
      },
      "checks": {
        "start": {
          "mode": "all",
          "items": [
            {
              "type": "command",
              "command": "docker compose ps",
              "retry": {
                "maxAttempts": 10,
                "delayMs": 1000
              }
            }
          ]
        },
        "status": {
          "mode": "all",
          "items": [
            {
              "type": "command",
              "command": "docker compose ps"
            }
          ]
        }
      }
    },
    {
      "id": "frontend",
      "kind": "project-command",
      "interactive": true,
      "tabName": "frontend",
      "workingDirectory": "C:\\PROJETS\\lebonplan\\lebonplan-frontend",
      "command": "bun dev:full",
      "dependsOn": [
        "docker-compose"
      ],
      "startPolicy": {
        "defaultAction": "ask"
      },
      "stopPolicy": {
        "defaultAction": "always"
      },
      "checks": {
        "start": {
          "mode": "all",
          "items": [
            {
              "type": "fixed-delay",
              "delayMs": 5000
            }
          ]
        },
        "status": {
          "mode": "any",
          "items": [
            {
              "type": "process",
              "name": "node"
            },
            {
              "type": "http",
              "url": "http://127.0.0.1:3000/health",
              "expectStatus": [200]
            }
          ]
        }
      }
    }
  ]
}
