{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "devlaunch/manifest/v1",
  "title": "devlaunch manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "terminal", "apps", "services"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "rootPath", "platform"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "rootPath": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "const": "windows" }
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "reuseWindow"],
      "properties": {
        "engine": { "type": "string", "const": "windows-terminal" },
        "reuseWindow": { "type": "boolean" }
      }
    },
    "apps": {
      "type": "array",
      "items": { "$ref": "#/$defs/app" }
    },
    "services": {
      "type": "array",
      "items": { "$ref": "#/$defs/service" }
    }
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultAction"],
      "properties": {
        "defaultAction": {
          "type": "string",
          "enum": ["always", "ask", "never"]
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "delayMs"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "delayMs": { "type": "integer", "minimum": 0 }
      }
    },
    "checkItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["command", "port", "process", "http", "fixed-delay"]
        },
        "command": { "type": "string", "minLength": 1 },
        "workingDirectory": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "host": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "expectStatus": {
          "type": "array",
          "items": { "type": "integer", "minimum": 100, "maximum": 599 },
          "minItems": 1
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "delayMs": { "type": "integer", "minimum": 0 },
        "retry": { "$ref": "#/$defs/retry" }
      }
    },
    "checkGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "items"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["all", "any"]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkItem" }
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "status"],
      "properties": {
        "start": { "$ref": "#/$defs/checkGroup" },
        "status": { "$ref": "#/$defs/checkGroup" }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["executable", "command"]
        },
        "path": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "dependsOn", "launch", "startPolicy", "stopPolicy", "checks"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "launch": { "$ref": "#/$defs/launch" },
        "startPolicy": { "$ref": "#/$defs/policy" },
        "stopPolicy": { "$ref": "#/$defs/policy" },
        "checks": { "$ref": "#/$defs/checks" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "interactive", "tabName", "workingDirectory", "command", "dependsOn", "startPolicy", "stopPolicy", "checks"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "interactive": { "type": "boolean" },
        "tabName": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "workingDirectory": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "startPolicy": { "$ref": "#/$defs/policy" },
        "stopPolicy": { "$ref": "#/$defs/policy" },
        "checks": { "$ref": "#/$defs/checks" }
      }
    }
  }
}
